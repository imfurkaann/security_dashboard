{
  "name": "security-backend",
  "version": "1.0.0",
  "description": "Security Management Backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "health": "node healthcheck.js",
    "test": "jest --coverage --forceExit --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:auth": "jest --testPathPattern=auth.test.ts --forceExit",
    "test:visitors": "jest --testPathPattern=visitors.test.ts --forceExit",
    "test:vehicles": "jest --testPathPattern=vehicleRecords.test.ts --forceExit",
    "test:fire": "jest --testPathPattern=fireAlarms.test.ts --forceExit",
    "test:incidents": "jest --testPathPattern=incidents.test.ts --forceExit",
    "test:statistics": "jest --testPathPattern=statistics.test.ts --forceExit",
    "test:security": "jest --testPathPattern=security.test.ts --forceExit",
    "test:admin": "jest --testPathPattern=admin.test.ts --forceExit",
    "test:validation": "jest --testPathPattern=validation.test.ts --forceExit",
    "test:all": "node tests/runAllTests.js",
    "test:coverage": "jest --coverage --forceExit --detectOpenHandles --coverageReporters=text --coverageReporters=html"
  },
  "keywords": [
    "security",
    "management",
    "api"
  ],
  "author": "Furkan",
  "license": "ISC",
  "dependencies": {
    "@types/archiver": "^7.0.0",
    "@types/multer": "^2.0.0",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "archiver": "^7.0.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "docx": "^9.5.1",
    "dotenv": "^16.5.0",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-validator": "^7.2.1",
    "html-to-docx": "^1.8.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "pg": "^8.14.1",
    "pino": "^10.3.1",
    "qrcode-terminal": "^0.12.0",
    "uuid": "^11.1.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.11",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
