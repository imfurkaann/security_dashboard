# ====================================
# Security Management System - Environment Variables
# ====================================
# DİKKAT: Bu dosyayı .env olarak kopyalayın ve değerleri doldurun
# .env dosyası ASLA git'e commit edilmemelidir!

# ====================================
# VERİTABANI AYARLARI
# ====================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=security_db
DB_USER=your_db_user
DB_PASSWORD=your_secure_db_password

# ====================================
# JWT AYARLARI (KRİTİK GÜVENLİK)
# ====================================
# Aşağıdaki komutla güçlü bir secret oluşturun:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_very_long_and_secure_jwt_secret_at_least_64_characters_here
JWT_EXPIRE=8h

# ====================================
# SUNUCU AYARLARI
# ====================================
PORT=5000
NODE_ENV=development

# ====================================
# FRONTEND URL (CORS için)
# ====================================
FRONTEND_URL=http://localhost:5173

# ====================================
# PRODUCTION İÇİN EK AYARLAR
# ====================================
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100

# ====================================
# WHATSAPP GRUBU (OPSİYONEL)
# ====================================
# WhatsApp grup numarası (905xxxxxxxxx formatında, başında + veya 90 olmadan)
WHATSAPP_GROUP_NUMBER=905xxxxxxxxx
